---
import PublicLayout from "../layouts/PublicLayout.astro";
import { HeroIsland } from "../islands/home/HeroIsland.tsx";
import { HomeDataIsland } from "../islands/home/HomeDataIsland.tsx";
import { setSsrLocale } from "../lib/i18n.ts";
import * as m from "../paraglide/messages.js";
const locale = Astro.currentLocale ?? "es";
setSsrLocale(locale);
---

<PublicLayout title={m.nav_home()} fullWidth={true} activePage="inicio">
  <HeroIsland client:load />

  <!-- All dynamic sections: Stats, Featured, Collections, CTA, News -->
  <HomeDataIsland client:load />
</PublicLayout>

<!-- All styles in HomeDataIsland.css -->

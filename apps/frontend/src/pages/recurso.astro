---
import PublicLayout from "../layouts/PublicLayout.astro";
import { ResourceDetailIsland } from "../islands/catalog/ResourceDetailIsland.tsx";
---

<PublicLayout title="Recurso" showNavSearch={true}>
  <ResourceDetailIsland client:load />
</PublicLayout>

<style is:global>
  /* ===================================================================
     Resource Detail Page — Stitch design alignment
     =================================================================== */

  /* -- Page container ------------------------------------------------ */
  .detail-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-24) var(--space-6) var(--space-20);
  }

  /* -- Breadcrumb ---------------------------------------------------- */
  .breadcrumb {
    color: var(--color-on-surface-variant);
    font-size: var(--text-body-sm);
    margin-bottom: var(--space-6);
  }

  .breadcrumb a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .breadcrumb .sep {
    margin: 0 var(--space-1);
    color: var(--color-outline);
  }

  /* -- Header -------------------------------------------------------- */
  .detail-header {
    margin-bottom: var(--space-12);
  }

  .detail-header-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .detail-status-badge {
    display: inline-block;
    background: var(--color-secondary-fixed);
    color: var(--color-on-secondary-fixed);
    font-size: 0.625rem;     /* text-[10px] */
    font-weight: var(--weight-bold);
    padding: 0.25rem 0.625rem; /* px-2.5 py-1 */
    border-radius: 0.125rem;  /* rounded-sm */
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  .detail-status-badge.draft {
    background: var(--color-tertiary-fixed);
    color: var(--color-on-tertiary-fixed);
  }

  .detail-status-badge.review {
    background: var(--color-primary-fixed);
    color: var(--color-on-primary-fixed);
  }

  .detail-status-badge.archived {
    background: var(--color-surface-container-high);
    color: var(--color-on-surface-variant);
  }

  .detail-date {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-on-surface-variant);
    font-size: var(--text-body-md);
  }

  .detail-date .material-symbols-outlined {
    font-size: var(--text-body-md);
  }

  .detail-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem); /* text-4xl md:text-5xl */
    font-weight: var(--weight-extrabold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-on-surface);
    line-height: 1.1;
    margin: 0 0 var(--space-6);
  }

  .detail-author-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .detail-author-row {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .detail-author {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .detail-author-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-full);
    overflow: hidden;
    background: var(--color-surface-container);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: var(--color-on-surface-variant);
    font-weight: var(--weight-bold);
    flex-shrink: 0;
  }

  .detail-author-name {
    font-weight: var(--weight-bold);
    font-family: var(--font-display);
    color: var(--color-on-surface);
  }

  .detail-author-role {
    font-size: var(--text-body-md);
    color: var(--color-on-surface-variant);
  }

  .detail-license {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-on-surface-variant);
  }

  .detail-license .material-symbols-outlined {
    color: var(--color-secondary);
  }

  .detail-license-text {
    font-size: var(--text-body-md);
    font-weight: var(--weight-medium);
    color: var(--color-on-surface-variant);
  }

  /* -- Content grid (12-col) ----------------------------------------- */
  .detail-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .detail-content {
      grid-template-columns: repeat(12, 1fr);
    }
  }

  .detail-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  @media (min-width: 1024px) {
    .detail-main {
      grid-column: span 8;
    }
  }

  .detail-sidebar-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  @media (min-width: 1024px) {
    .detail-sidebar-col {
      grid-column: span 4;
    }
  }

  /* -- Action buttons ------------------------------------------------ */
  .detail-actions-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--color-surface-container-low);
    border-radius: var(--radius-lg);
  }

  .detail-action-primary {
    flex: 1;
    min-width: 180px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-radius: var(--radius-full);
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: 1rem;
    border: none;
    cursor: pointer;
    box-shadow: var(--shadow-primary);
    text-decoration: none;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  .detail-action-primary:hover {
    transform: scale(1.02);
    text-decoration: none;
    color: var(--color-on-primary);
  }

  .detail-action-outline {
    flex: 1;
    min-width: 180px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    background: var(--color-surface-container-lowest);
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-full);
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: 1rem;
    cursor: pointer;
    text-decoration: none;
    transition: background-color var(--transition-fast), transform var(--transition-fast);
  }

  .detail-action-outline:hover {
    background: rgba(0, 63, 177, 0.05);
    text-decoration: none;
    color: var(--color-primary);
  }

  /* -- Preview area -------------------------------------------------- */
  .detail-preview-section h2,
  .description-section h2,
  .keywords-section h2,
  .embed-section h2,
  .files-section h2,
  .detail-comments-section h2 {
    font-family: var(--font-display);
    font-size: 1.5rem; /* text-2xl */
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-6);
    color: var(--color-on-surface);
  }

  .elpx-preview-section {
    margin: 0;
  }

  .elpx-preview-section h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-6);
    color: var(--color-on-surface);
  }

  .elpx-preview-wrapper {
    border-radius: var(--radius-2xl);
    overflow: hidden;
    background: var(--color-surface-container-highest);
    position: relative;
  }

  .elpx-preview-iframe {
    width: 100%;
    height: 600px;
    border: none;
    display: block;
  }

  .preview-play-overlay {
    position: absolute;
    inset: 0;
    background: rgba(18, 28, 40, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-base);
    cursor: pointer;
  }

  .elpx-preview-wrapper:hover .preview-play-overlay {
    opacity: 1;
  }

  .preview-play-btn {
    background: var(--color-surface-container-lowest);
    border-radius: var(--radius-full);
    padding: var(--space-4);
    color: var(--color-primary);
    box-shadow: var(--shadow-xl);
    display: flex;
  }

  /* -- Description --------------------------------------------------- */
  .description-section p {
    font-size: 1rem;
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-variant);
    white-space: pre-line;
  }

  /* -- Keywords ------------------------------------------------------ */
  .keywords-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .keyword {
    display: inline-block;
    padding: 0.25rem var(--space-3);
    background: var(--color-surface-container-lowest);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    color: var(--color-on-surface);
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  .keyword:hover {
    border-color: var(--color-primary);
  }

  /* -- Files --------------------------------------------------------- */
  .files-grid {
    display: grid;
    gap: var(--space-3);
  }

  .file-card {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface-container-lowest);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: background-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .file-card:hover {
    background: var(--color-surface-bright);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
  }

  .file-icon {
    font-size: 1.5rem;
  }

  .file-info {
    display: flex;
    flex-direction: column;
  }

  .file-name {
    font-weight: var(--weight-medium);
    color: var(--color-primary);
    font-size: var(--text-body-md);
  }

  .file-size {
    font-size: var(--text-body-sm);
    color: var(--color-on-surface-variant);
  }

  /* -- Embed / Ponlo en tu web --------------------------------------- */
  .embed-section {
    /* inherits section spacing from detail-main > section */
  }

  .embed-description {
    font-size: var(--text-body-md);
    color: var(--color-on-surface-variant);
    margin-bottom: var(--space-3);
  }

  .embed-code-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .embed-textarea {
    width: 100%;
    padding: var(--space-3);
    background: var(--color-surface-container-highest);
    border: none;
    border-radius: var(--radius-md);
    font-family: monospace;
    font-size: 0.8125rem;
    color: var(--color-on-surface);
    resize: vertical;
    line-height: 1.5;
  }

  .embed-textarea:focus {
    outline: none;
    box-shadow: 0 0 0 2px rgba(0, 63, 177, 0.3);
  }

  .embed-copy-btn {
    align-self: flex-end;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-body-md);
    font-weight: var(--weight-semibold);
    font-family: var(--font-display);
    color: var(--color-primary);
    background: transparent;
    border: 1px solid var(--color-outline-variant);
    border-radius: 9999px;
    cursor: pointer;
    transition: all 200ms ease;
  }

  .embed-copy-btn:hover {
    background: var(--color-surface-container-low);
    border-color: var(--color-primary);
  }

  .embed-copy-btn:active {
    transform: scale(0.95);
  }

  .embed-copy-btn .material-symbols-outlined {
    font-size: 18px;
  }

  .embed-copy-success {
    border-color: var(--color-secondary);
    color: var(--color-secondary);
  }

  /* -- Comments section ---------------------------------------------- */
  .detail-comments-section {
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-surface-container-high);
  }

  .detail-comments-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-8);
  }

  .detail-comments-header h2 {
    margin-bottom: 0;
  }

  .detail-star-display {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    color: var(--color-tertiary);
  }

  .detail-star-display .material-symbols-outlined {
    font-variation-settings: 'FILL' 1;
  }

  .detail-star-score {
    margin-left: var(--space-2);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
  }

  /* Comment input */
  .detail-comment-input {
    background: var(--color-surface-container-low);
    padding: var(--space-6);
    border-radius: var(--radius-2xl);
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .detail-comment-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-full);
    background: var(--color-surface-container-highest);
    flex-shrink: 0;
  }

  .detail-comment-input-inner {
    flex: 1;
  }

  .detail-comment-input textarea {
    width: 100%;
    background: var(--color-surface-container-lowest);
    border: none;
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    font-size: var(--text-body-md);
    font-family: var(--font-body);
    color: var(--color-on-surface);
    resize: vertical;
    transition: box-shadow var(--transition-fast);
  }

  .detail-comment-input textarea:focus {
    outline: none;
    box-shadow: 0 0 0 2px rgba(0, 63, 177, 0.2);
  }

  .detail-comment-input textarea::placeholder {
    color: rgba(67, 70, 84, 0.5);
  }

  .detail-comment-submit {
    margin-top: var(--space-4);
    display: flex;
    justify-content: flex-end;
  }

  .detail-comment-submit button {
    background: var(--color-primary);
    color: var(--color-on-primary);
    padding: var(--space-2) var(--space-6);
    border-radius: var(--radius-full);
    font-family: var(--font-display);
    font-size: var(--text-body-md);
    font-weight: var(--weight-bold);
    border: none;
    cursor: pointer;
    transition: opacity var(--transition-fast);
  }

  .detail-comment-submit button:hover {
    opacity: 0.9;
  }

  /* Comment card */
  .detail-comment-card {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .detail-comment-card-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-full);
    background: var(--color-surface-container-highest);
    flex-shrink: 0;
    overflow: hidden;
  }

  .detail-comment-card-body {
    flex: 1;
    background: var(--color-surface-container-lowest);
    padding: var(--space-6);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-sm);
  }

  .detail-comment-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }

  .detail-comment-card-author {
    font-weight: var(--weight-bold);
    font-family: var(--font-display);
  }

  .detail-comment-card-date {
    font-size: 0.75rem;
    color: var(--color-on-surface-variant);
  }

  .detail-comment-card-text {
    font-size: var(--text-body-md);
    color: var(--color-on-surface-variant);
    margin-bottom: var(--space-3);
    line-height: var(--leading-relaxed);
  }

  .detail-comment-card-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .detail-comment-card-actions button {
    font-size: 0.75rem;
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .detail-comment-card-actions button:hover {
    text-decoration: underline;
  }

  /* -- Right sidebar ------------------------------------------------- */
  .detail-meta-card {
    background: var(--color-surface-container-low);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    position: sticky;
    top: var(--space-24);
  }

  .detail-meta-card .meta-section {
    margin-bottom: 0;
  }

  .detail-meta-card .meta-section + .meta-section {
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-surface-container-highest);
    margin-top: var(--space-8);
  }

  .meta-section-title {
    font-size: 0.75rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--color-on-surface-variant);
    opacity: 0.6;
    margin-bottom: var(--space-6);
  }

  .meta-row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .meta-row:last-child {
    margin-bottom: 0;
  }

  .meta-row-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-lg);
    background: var(--color-surface-container-lowest);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }

  .meta-row-label {
    font-size: 0.75rem;
    color: var(--color-on-surface-variant);
  }

  .meta-row-value {
    font-weight: var(--weight-bold);
  }

  /* Tags */
  .meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .meta-tag {
    padding: 0.25rem var(--space-3);
    background: var(--color-surface-container-lowest);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  .meta-tag:hover {
    border-color: var(--color-primary);
  }

  /* Competence chips in sidebar */
  .meta-competence-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .meta-competence-chip {
    background: var(--color-secondary-fixed);
    padding: 0.25rem var(--space-2);
    border-radius: var(--radius-sm);
    font-size: 0.625rem;
    font-weight: var(--weight-bold);
    color: var(--color-on-secondary-fixed);
  }

  /* Action buttons in sidebar */
  .meta-actions {
    display: flex;
    gap: var(--space-4);
  }

  .meta-action-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-size: var(--text-body-md);
    font-weight: var(--weight-bold);
    padding: var(--space-2) 0;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-outline-variant);
    background: transparent;
    color: var(--color-on-surface);
    cursor: pointer;
    transition: background-color var(--transition-fast);
  }

  .meta-action-btn:hover {
    background: var(--color-surface-container-lowest);
  }

  .meta-action-btn .material-symbols-outlined {
    font-size: 1.125rem;
  }

  .detail-action-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.5rem;
    height: 1.5rem;
    padding: 0 0.375rem;
    font-size: 0.75rem;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.3);
    border-radius: 9999px;
    margin-left: 0.25rem;
  }

  .meta-action-btn-success {
    border-color: var(--color-secondary);
    color: var(--color-secondary);
  }

  /* -- Related resources --------------------------------------------- */
  .detail-related {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .detail-related h3 {
    font-size: 1.125rem;
    font-weight: var(--weight-bold);
    font-family: var(--font-display);
    padding: 0 var(--space-2);
  }

  .related-card {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--color-surface-container-lowest);
    border-radius: var(--radius-2xl);
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: box-shadow var(--transition-base);
  }

  .related-card:hover {
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

  .related-card-thumb {
    width: 5rem;
    height: 5rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface-container);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .related-card-thumb .material-symbols-outlined {
    font-size: 2rem;
    color: var(--color-outline-variant);
  }

  .related-card-title {
    font-size: var(--text-body-md);
    font-weight: var(--weight-bold);
    font-family: var(--font-display);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--transition-fast);
  }

  .related-card:hover .related-card-title {
    color: var(--color-primary);
  }

  .related-card-meta {
    font-size: 0.625rem;
    color: var(--color-on-surface-variant);
    margin-top: var(--space-2);
  }

  /* -- Pill overrides for detail header ------------------------------ */
  .pill-status-draft {
    background: var(--color-tertiary-fixed);
    color: var(--color-on-tertiary-fixed);
  }

  .pill-status-review {
    background: var(--color-primary-fixed);
    color: var(--color-on-primary-fixed);
  }

  .pill-status-published {
    background: var(--color-secondary-fixed);
    color: var(--color-on-secondary-fixed);
  }

  .pill-status-archived {
    background: var(--color-surface-container-high);
    color: var(--color-on-surface-variant);
  }

  /* -- Social section (tabs wrapper) --------------------------------- */
  .detail-social {
    margin: 0;
  }

  /* -- Empty / Loading states ---------------------------------------- */
  .empty-state {
    text-align: center;
    padding: var(--space-12) var(--space-4);
    color: var(--color-on-surface-variant);
  }


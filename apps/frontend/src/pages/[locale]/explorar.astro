---
import { locales, baseLocale } from "../../paraglide/runtime.js";
import PublicLayout from "../../layouts/PublicLayout.astro";
import { CatalogIsland } from "../../islands/catalog/CatalogIsland.tsx";
import { CatalogSearchIsland } from "../../islands/catalog/CatalogSearchIsland.tsx";
import "../../styles/catalog.css";

export function getStaticPaths() {
  return locales
    .filter((l) => l !== baseLocale)
    .map((locale) => ({ params: { locale } }));
}

const initialQuery = Astro.url.searchParams.get("q") ?? "";
---

<PublicLayout title="Explorar recursos" showNavSearch={true} activePage="explorar">
  <CatalogIsland client:load />
</PublicLayout>

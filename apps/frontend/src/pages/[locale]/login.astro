---
import { locales, baseLocale } from "../../paraglide/runtime.js";
import PublicLayout from "../../layouts/PublicLayout.astro";
import { LoginIsland } from "../../islands/auth/LoginIsland.tsx";

export function getStaticPaths() {
  return locales
    .filter((l) => l !== baseLocale)
    .map((locale) => ({ params: { locale } }));
}
---

<PublicLayout title="Iniciar sesión">
  <LoginIsland client:load />
</PublicLayout>

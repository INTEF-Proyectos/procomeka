---
import { locales, baseLocale } from "../../paraglide/runtime.js";
import PublicLayout from "../../layouts/PublicLayout.astro";

export function getStaticPaths() {
  return locales
    .filter((l) => l !== baseLocale)
    .map((locale) => ({ params: { locale } }));
}
---

<PublicLayout title="Editar recurso" showNavSearch={true}>
  <div id="edit-page" class="edit-page">
    <div id="edit-loading" class="edit-loading">Cargando recurso...</div>
    <div id="edit-auth" class="edit-auth" style="display:none;">
      <span class="material-symbols-outlined" aria-hidden="true">lock</span>
      <p>Necesitas <a id="login-link" href="#">iniciar sesión</a> para editar recursos.</p>
    </div>
    <div id="edit-notfound" class="edit-auth" style="display:none;">
      <span class="material-symbols-outlined" aria-hidden="true">search_off</span>
      <p>Recurso no encontrado. <a href="/">Volver al inicio</a></p>
    </div>
    <div id="edit-content" style="display:none;"></div>
  </div>

  <!-- eXeLearning editor modal (fullscreen) -->
  <div id="exe-editor-modal" class="exe-modal" style="display:none;">
    <div class="exe-modal-bar">
      <div class="exe-modal-bar-left">
        <span class="material-symbols-outlined" aria-hidden="true">edit_note</span>
        <span class="exe-modal-title">Editor eXeLearning</span>
        <span id="exe-status" class="exe-modal-status">Cargando...</span>
      </div>
      <div class="exe-modal-bar-right">
        <button type="button" id="exe-save-btn" class="exe-save-btn" disabled>
          <span class="material-symbols-outlined">save</span>
          Guardar
        </button>
        <button type="button" id="exe-close-btn" class="exe-close-btn">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
    </div>
    <iframe id="exe-iframe" class="exe-modal-iframe" src="about:blank" title="Editor eXeLearning"></iframe>
    <div id="exe-saving-overlay" class="exe-saving-overlay" style="display:none;">
      <span>Guardando cambios...</span>
    </div>
  </div>
</PublicLayout>

<script>
  import { getApiClient } from "../../lib/get-api-client.ts";
  import { url } from "../../lib/paths.ts";
  import type { Resource } from "../../lib/api-client.ts";

  const loadingEl = document.getElementById("edit-loading")!;
  const authEl = document.getElementById("edit-auth")!;
  const notFoundEl = document.getElementById("edit-notfound")!;
  const contentEl = document.getElementById("edit-content")!;
  const loginLink = document.getElementById("login-link") as HTMLAnchorElement;
  if (loginLink) loginLink.href = url("login");

  const STATUS_LABELS: Record<string, { label: string; cssClass: string }> = {
    draft: { label: "Borrador", cssClass: "edit-badge-draft" },
    review: { label: "En revisión", cssClass: "edit-badge-review" },
    published: { label: "Publicado", cssClass: "edit-badge-published" },
    archived: { label: "Archivado", cssClass: "edit-badge-archived" },
  };

  const TRANSITION_RULES: Record<string, { to: string; label: string; icon: string; cssClass: string; minRole: string }[]> = {
    draft: [
      { to: "review", label: "Enviar a revisión", icon: "rate_review", cssClass: "edit-wf-btn-gold", minRole: "author" },
      { to: "published", label: "Publicar directamente", icon: "check_circle", cssClass: "edit-wf-btn-green", minRole: "editor" },
    ],
    review: [
      { to: "draft", label: "Devolver a borrador", icon: "undo", cssClass: "edit-wf-btn-outline", minRole: "curator" },
      { to: "published", label: "Publicar", icon: "check_circle", cssClass: "edit-wf-btn-green", minRole: "curator" },
    ],
    published: [{ to: "archived", label: "Archivar", icon: "archive", cssClass: "edit-wf-btn-outline", minRole: "curator" }],
    archived: [{ to: "draft", label: "Restaurar a borrador", icon: "restore", cssClass: "edit-wf-btn-outline", minRole: "curator" }],
  };

  const ROLE_LEVELS: Record<string, number> = { reader: 0, author: 1, editor: 2, curator: 3, admin: 4 };

  function esc(s: string) { const d = document.createElement("div"); d.textContent = s; return d.innerHTML; }

  function formatFileSize(bytes: number): string {
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
  }

  function formatDate(d: string | number | Date | null | undefined) {
    if (!d) return "";
    return new Date(d).toLocaleDateString("es-ES", { year: "numeric", month: "long", day: "numeric" });
  }

  async function init() {
    const params = new URLSearchParams(window.location.search);
    const id = params.get("id");
    const isNew = params.get("new") === "1";
    if (!id) { loadingEl.style.display = "none"; notFoundEl.style.display = "flex"; return; }

    try {
      const api = await getApiClient();
      const [session, resource] = await Promise.all([
        api.getSession().catch(() => null),
        api.getResourceById(id).catch(() => null),
      ]);

      loadingEl.style.display = "none";

      if (!session?.user) { authEl.style.display = "flex"; return; }
      if (!resource) { notFoundEl.style.display = "flex"; return; }

      const userRole = session.user.role ?? "reader";
      const userLevel = ROLE_LEVELS[userRole] ?? 0;
      if (userLevel < 1) { authEl.style.display = "flex"; return; }

      // Load elpx project info to get preview URL
      const elpx = await api.getElpxProject(id).catch(() => null);
      if (elpx?.hasPreview && elpx.previewUrl) {
        (resource as Record<string, unknown>).elpxPreview = { hash: elpx.hash, previewUrl: elpx.previewUrl };
      }

      renderEditor(resource, userRole, elpx, isNew);
      contentEl.style.display = "block";

      // Initialise the multi-file uploader after the DOM is rendered
      const uploadPanel = document.getElementById("edit-multiupload-panel");
      if (uploadPanel) {
        const { initResourceUploader } = await import("../../lib/resource-uploader.ts");
        await initResourceUploader({
          resourceId: resource.id,
          root: uploadPanel,
          api,
          onUploadComplete: isNew ? undefined : async (count) => {
            const statusEl = document.getElementById("elpx-auto-status");
            if (!statusEl) return;
            statusEl.textContent = "Generando paquete .elpx...";
            statusEl.className = "edit-upload-status edit-upload-loading";
            statusEl.style.display = "block";
            try {
              await api.generateElpx(resource.id);
              statusEl.textContent = count > 0
                ? `${count} archivo${count !== 1 ? "s" : ""} subido${count !== 1 ? "s" : ""}. Paquete .elpx actualizado.`
                : "Paquete .elpx actualizado.";
              statusEl.className = "edit-upload-status edit-upload-success";
              setTimeout(() => { statusEl.style.display = "none"; }, 5000);
            } catch (err) {
              statusEl.textContent = `Error al generar .elpx: ${(err as Error).message || "Error desconocido"}`;
              statusEl.className = "edit-upload-status edit-upload-error";
            }
          },
        });
      }
    } catch {
      loadingEl.style.display = "none";
      notFoundEl.style.display = "flex";
    }
  }

  function renderEditor(resource: Resource, userRole: string, elpx: { hash: string; elpxFileUrl: string | null; originalFilename: string; hasPreview: boolean | number; previewUrl: string | null; metadata: { title: string; description: string; author: string; license: string; language: string } | null } | null, isNew = false) {
    const st = STATUS_LABELS[resource.editorialStatus] ?? STATUS_LABELS.draft;
    const date = formatDate(resource.updatedAt || resource.createdAt);
    const previewUrl = resource.elpxPreview?.previewUrl ?? "";
    const userLevel = ROLE_LEVELS[userRole] ?? 0;
    const isAutoGenerated = elpx?.originalFilename === "recurso-generado.elpx";
    const showMultiUpload = isNew || !elpx || isAutoGenerated;
    const showDirectUpload = !isNew && elpx !== null && !isAutoGenerated;

    // Workflow buttons
    const transitions = TRANSITION_RULES[resource.editorialStatus] ?? [];
    const wfButtons = transitions
      .filter((t) => userLevel >= (ROLE_LEVELS[t.minRole] ?? 99))
      .map((t) => `<button type="button" class="edit-wf-btn ${t.cssClass}" data-status="${t.to}"><span class="material-symbols-outlined">${t.icon}</span>${esc(t.label)}</button>`)
      .join("");

    contentEl.innerHTML = `
      <!-- Header -->
      <div class="edit-header">
        <div class="edit-header-top">
          <span class="edit-badge ${st.cssClass}">${esc(st.label)}</span>
          ${date ? `<span class="edit-date"><span class="material-symbols-outlined">calendar_today</span>${esc(date)}</span>` : ""}
        </div>
        <a href="${url(`recurso?slug=${resource.slug}`)}" class="edit-view-link">
          <span class="material-symbols-outlined">visibility</span>
          Ver ficha pública
        </a>
      </div>

      <div id="edit-error" class="edit-msg edit-msg-error" role="alert" style="display:none;"></div>
      <div id="edit-success" class="edit-msg edit-msg-success" role="status" style="display:none;"></div>

      <!-- Form as detail-style layout -->
      <form id="edit-form" class="edit-grid" novalidate>
        <!-- Left column -->
        <div class="edit-main">
          <div class="edit-field edit-field-title">
            <label for="ed-title">Título</label>
            <input type="text" id="ed-title" value="${isNew ? "" : esc(resource.title)}" required placeholder="Título del recurso" />
            <span id="ed-title-error" class="edit-field-error"></span>
          </div>

          ${previewUrl ? `
          <div class="edit-preview-section">
            <div class="edit-preview-header">
              <h3>Previsualización</h3>
              <button type="button" class="edit-exe-btn" id="open-exe-editor">
                <span class="material-symbols-outlined">edit_note</span>
                Editar en eXeLearning
              </button>
            </div>
            <div class="edit-preview-wrapper">
              <iframe src="${previewUrl}" class="edit-preview-iframe" sandbox="allow-scripts allow-same-origin allow-popups allow-popups-to-escape-sandbox" loading="lazy" title="Vista previa"></iframe>
            </div>
          </div>` : ""}

          <!-- Multi-file uploader (all formats) — only for auto-generated .elpx -->
          ${showMultiUpload ? `<div id="edit-multiupload-panel" class="edit-files-section">
            <h3>Archivos adjuntos</h3>
            <div data-upload-dropzone class="edit-dropzone" id="edit-multi-dropzone" tabindex="0">
              <label class="edit-file-label">
                <span class="material-symbols-outlined">upload_file</span>
                <span>Seleccionar archivos</span>
                <input data-upload-input type="file" multiple />
              </label>
              <p class="edit-drop-hint">o arrastra aquí (PDF, DOCX, imágenes, vídeo…)</p>
            </div>
            <div data-upload-feedback class="edit-upload-status" aria-live="polite"></div>
            <div class="edit-upload-progress-row">
              <progress data-global-progress max="100" value="0" style="width:100%;"></progress>
              <span data-global-progress-label style="font-size:0.85rem;color:#555;">Sin subidas activas</span>
            </div>
            <ul data-upload-queue class="edit-upload-queue"><li style="color:#888;font-size:0.9rem;">No hay archivos en cola.</li></ul>
            <ul data-persisted-uploads style="display:none;"></ul>
            <div class="edit-files-list-header">
              <span>Archivos del recurso</span>
            </div>
            <ul data-media-list class="edit-media-list"><li style="color:#888;font-size:0.9rem;">No hay archivos adjuntos todavía.</li></ul>
            <div id="elpx-auto-status" class="edit-upload-status" style="display:none;" aria-live="polite"></div>
          </div>` : ""}

          <!-- Upload .elpx section (direct single .elpx) — only for directly uploaded .elpx -->
          ${showDirectUpload ? `<div class="edit-upload-section">
            <h3>${previewUrl ? "Actualizar archivo .elpx" : "Subir archivo .elpx directamente"}</h3>
            <div id="edit-dropzone" class="edit-dropzone" tabindex="0">
              <label class="edit-file-label">
                <span class="material-symbols-outlined">upload_file</span>
                <span>Seleccionar archivo .elpx</span>
                <input type="file" id="edit-file-input" accept=".elpx,.elp" />
              </label>
              <p class="edit-drop-hint">o arrastra aquí</p>
            </div>
            <div id="edit-upload-status" class="edit-upload-status" style="display:none;"></div>
          </div>` : ""}

          <div class="edit-field">
            <label for="ed-description">Descripción</label>
            <textarea id="ed-description" rows="6" required placeholder="Describe el contenido, objetivos y destinatarios...">${isNew ? "" : esc(resource.description)}</textarea>
            <span id="ed-description-error" class="edit-field-error"></span>
          </div>

          ${isNew ? `
          <div class="edit-form-row">
            <div class="edit-field">
              <label for="ed-language">Idioma</label>
              <select id="ed-language">
                <option value="es" selected>Español</option>
                <option value="en">Inglés</option>
                <option value="ca">Catalán</option>
                <option value="eu">Euskera</option>
                <option value="gl">Gallego</option>
              </select>
            </div>
            <div class="edit-field">
              <label for="ed-license">Licencia</label>
              <select id="ed-license">
                <option value="cc-by" selected>CC BY</option>
                <option value="cc-by-sa">CC BY-SA</option>
                <option value="cc-by-nc">CC BY-NC</option>
                <option value="cc-by-nc-sa">CC BY-NC-SA</option>
                <option value="cc0">CC0</option>
              </select>
            </div>
          </div>
          <div class="edit-field">
            <label for="ed-resourceType">Tipo de recurso</label>
            <select id="ed-resourceType">
              <option value="documento">Documento</option>
              <option value="presentacion">Presentación</option>
              <option value="video">Vídeo</option>
              <option value="audio">Audio</option>
              <option value="imagen">Imagen</option>
              <option value="actividad-interactiva" selected>Actividad interactiva</option>
              <option value="secuencia-didactica">Secuencia didáctica</option>
              <option value="ejercicio">Ejercicio</option>
              <option value="evaluacion">Evaluación</option>
              <option value="proyecto">Proyecto</option>
            </select>
          </div>` : ""}

          <div class="edit-field">
            <label for="ed-author">Autor</label>
            <input type="text" id="ed-author" value="${esc(resource.author ?? "")}" placeholder="Nombre del autor" />
          </div>

          <div class="edit-field">
            <label for="ed-keywords">Palabras clave (separadas por comas)</label>
            <input type="text" id="ed-keywords" value="${esc(resource.keywords ?? "")}" placeholder="matemáticas, fracciones, visual" />
          </div>
        </div>

        <!-- Right sidebar -->
        <aside class="edit-sidebar">
          <!-- Actions card -->
          <div class="edit-sidebar-card">
            <h3 class="edit-sidebar-title">Acciones</h3>
            <button type="submit" class="edit-save-btn">
              <span class="material-symbols-outlined">save</span>
              ${isNew ? "Crear recurso" : "Guardar cambios"}
            </button>
            ${wfButtons ? `<div class="edit-wf-actions">${wfButtons}</div>` : ""}
            ${elpx?.metadata && (elpx.metadata.title || elpx.metadata.description) ? `
            <button type="button" id="apply-elpx-meta" class="edit-wf-btn edit-wf-btn-outline">
              <span class="material-symbols-outlined">auto_awesome</span>
              Aplicar metadatos del .elpx
            </button>` : ""}
          </div>

          <!-- Metadata card — hidden in creation mode (fields are in main column) -->
          ${!isNew ? `<div class="edit-sidebar-card">
            <h3 class="edit-sidebar-title">Metadatos</h3>

            <div class="edit-field">
              <label for="ed-language">Idioma</label>
              <select id="ed-language">
                <option value="es" ${resource.language === "es" ? "selected" : ""}>Español</option>
                <option value="en" ${resource.language === "en" ? "selected" : ""}>Inglés</option>
                <option value="ca" ${resource.language === "ca" ? "selected" : ""}>Catalán</option>
                <option value="eu" ${resource.language === "eu" ? "selected" : ""}>Euskera</option>
                <option value="gl" ${resource.language === "gl" ? "selected" : ""}>Gallego</option>
              </select>
            </div>

            <div class="edit-field">
              <label for="ed-license">Licencia</label>
              <select id="ed-license">
                <option value="cc-by" ${resource.license === "cc-by" ? "selected" : ""}>CC BY</option>
                <option value="cc-by-sa" ${resource.license === "cc-by-sa" ? "selected" : ""}>CC BY-SA</option>
                <option value="cc-by-nc" ${resource.license === "cc-by-nc" ? "selected" : ""}>CC BY-NC</option>
                <option value="cc-by-nc-sa" ${resource.license === "cc-by-nc-sa" ? "selected" : ""}>CC BY-NC-SA</option>
                <option value="cc0" ${resource.license === "cc0" ? "selected" : ""}>CC0</option>
              </select>
            </div>

            <div class="edit-field">
              <label for="ed-resourceType">Tipo de recurso</label>
              <select id="ed-resourceType">
                <option value="documento" ${resource.resourceType === "documento" ? "selected" : ""}>Documento</option>
                <option value="presentacion" ${resource.resourceType === "presentacion" ? "selected" : ""}>Presentación</option>
                <option value="video" ${resource.resourceType === "video" ? "selected" : ""}>Vídeo</option>
                <option value="audio" ${resource.resourceType === "audio" ? "selected" : ""}>Audio</option>
                <option value="imagen" ${resource.resourceType === "imagen" ? "selected" : ""}>Imagen</option>
                <option value="actividad-interactiva" ${resource.resourceType === "actividad-interactiva" ? "selected" : ""}>Actividad interactiva</option>
                <option value="secuencia-didactica" ${resource.resourceType === "secuencia-didactica" ? "selected" : ""}>Secuencia didáctica</option>
                <option value="ejercicio" ${resource.resourceType === "ejercicio" ? "selected" : ""}>Ejercicio</option>
                <option value="evaluacion" ${resource.resourceType === "evaluacion" ? "selected" : ""}>Evaluación</option>
                <option value="proyecto" ${resource.resourceType === "proyecto" ? "selected" : ""}>Proyecto</option>
              </select>
            </div>
          </div>` : ""}
        </aside>
      </form>
    `;

    // Wire form submission
    const form = document.getElementById("edit-form") as HTMLFormElement;
    const errorDiv = document.getElementById("edit-error")!;
    const successDiv = document.getElementById("edit-success")!;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorDiv.style.display = "none";
      successDiv.style.display = "none";

      const saveBtn = form.querySelector(".edit-save-btn") as HTMLButtonElement;
      saveBtn.disabled = true;
      saveBtn.innerHTML = `<span class="material-symbols-outlined">hourglass_empty</span>Guardando...`;

      try {
        const api = await getApiClient();
        const result = await api.updateResource(resource.id, {
          title: (document.getElementById("ed-title") as HTMLInputElement).value,
          description: (document.getElementById("ed-description") as HTMLTextAreaElement).value,
          language: (document.getElementById("ed-language") as HTMLSelectElement).value,
          license: (document.getElementById("ed-license") as HTMLSelectElement).value,
          resourceType: (document.getElementById("ed-resourceType") as HTMLSelectElement).value,
          author: (document.getElementById("ed-author") as HTMLInputElement)?.value || undefined,
          keywords: (document.getElementById("ed-keywords") as HTMLInputElement)?.value || undefined,
        });

        if (!result.ok) {
          if (result.details) {
            result.details.forEach((d: { field: string; message: string }) => {
              const errEl = document.getElementById(`ed-${d.field}-error`);
              if (errEl) errEl.textContent = d.message;
              const input = document.getElementById(`ed-${d.field}`);
              if (input) input.setAttribute("aria-invalid", "true");
            });
          }
          errorDiv.textContent = result.error ?? "Error al guardar";
          errorDiv.style.display = "block";
          return;
        }

        if (isNew) {
          saveBtn.innerHTML = `<span class="material-symbols-outlined">hourglass_empty</span>Generando .elpx...`;
          await api.generateElpx(resource.id);
          window.location.href = url(`editar?id=${resource.id}`);
          return;
        }

        successDiv.textContent = "Cambios guardados correctamente";
        successDiv.style.display = "block";
        setTimeout(() => { successDiv.style.display = "none"; }, 3000);
      } catch {
        errorDiv.textContent = "Error de conexión";
        errorDiv.style.display = "block";
      } finally {
        saveBtn.disabled = false;
        saveBtn.innerHTML = `<span class="material-symbols-outlined">save</span>${isNew ? "Crear recurso" : "Guardar cambios"}`;
      }
    });

    // Wire workflow buttons
    contentEl.querySelectorAll(".edit-wf-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const newStatus = (btn as HTMLElement).dataset.status!;
        errorDiv.style.display = "none";
        successDiv.style.display = "none";

        try {
          const api = await getApiClient();
          await api.updateResourceStatus(resource.id, newStatus);
          successDiv.textContent = `Estado actualizado a "${STATUS_LABELS[newStatus]?.label ?? newStatus}"`;
          successDiv.style.display = "block";
          // Reload to reflect new status
          setTimeout(() => window.location.reload(), 800);
        } catch {
          errorDiv.textContent = "Error al cambiar el estado";
          errorDiv.style.display = "block";
        }
      });
    });

    // Wire "Aplicar metadatos del .elpx" button
    const applyMetaBtn = document.getElementById("apply-elpx-meta");
    if (applyMetaBtn && elpx?.metadata) {
      applyMetaBtn.addEventListener("click", () => {
        const m = elpx.metadata!;
        if (m.title) (document.getElementById("ed-title") as HTMLInputElement).value = m.title;
        if (m.description) (document.getElementById("ed-description") as HTMLTextAreaElement).value = m.description;
        if (m.author) (document.getElementById("ed-author") as HTMLInputElement).value = m.author;
        if (m.language) {
          const sel = document.getElementById("ed-language") as HTMLSelectElement;
          if (sel.querySelector(`option[value="${m.language}"]`)) sel.value = m.language;
        }
        if (m.license) {
          const sel = document.getElementById("ed-license") as HTMLSelectElement;
          if (sel.querySelector(`option[value="${m.license}"]`)) sel.value = m.license;
        }
        applyMetaBtn.innerHTML = `<span class="material-symbols-outlined">check</span>Metadatos aplicados`;
        (applyMetaBtn as HTMLButtonElement).disabled = true;
      });
    }

    // Wire "Editar en eXeLearning" button
    const openExeBtn = document.getElementById("open-exe-editor");
    if (openExeBtn) {
      // Load elpx project info for the editor
      (async () => {
        try {
          const api = await getApiClient();
          const elpx = await api.getElpxProject(resource.id);
          if (elpx) {
            openExeBtn.addEventListener("click", () => {
              openExeEditor(resource.id, elpx.hash, elpx.elpxFileUrl, elpx.originalFilename);
            });
          } else {
            openExeBtn.setAttribute("disabled", "true");
            (openExeBtn as HTMLButtonElement).title = "No hay archivo .elpx asociado";
          }
        } catch {
          openExeBtn.setAttribute("disabled", "true");
        }
      })();
    }

    // Wire file upload
    const dropzone = document.getElementById("edit-dropzone");
    const fileInput = document.getElementById("edit-file-input") as HTMLInputElement | null;
    const uploadStatus = document.getElementById("edit-upload-status");

    if (dropzone && fileInput && uploadStatus) {
      fileInput.addEventListener("change", () => {
        const f = fileInput.files?.[0];
        if (f) handleFileUpload(f, resource.id, uploadStatus);
      });

      dropzone.addEventListener("dragover", (e) => { e.preventDefault(); dropzone.classList.add("is-dragover"); });
      dropzone.addEventListener("dragleave", () => { dropzone.classList.remove("is-dragover"); });
      dropzone.addEventListener("drop", (e) => {
        e.preventDefault();
        dropzone.classList.remove("is-dragover");
        const f = e.dataTransfer?.files[0];
        if (f) handleFileUpload(f, resource.id, uploadStatus);
      });
    }
  }

  async function handleFileUpload(file: File, resourceId: string, statusEl: HTMLElement) {
    statusEl.textContent = "Subiendo archivo...";
    statusEl.className = "edit-upload-status edit-upload-loading";
    statusEl.style.display = "block";

    try {
      const isPreview = (window as Record<string, unknown>).__PREVIEW_MODE__;

      if (isPreview) {
        const { saveElpxInPreview } = await import("../../lib/elpx-preview-service.ts");
        await saveElpxInPreview({ resourceId, blob: file, filename: file.name });
      } else {
        const formData = new FormData();
        formData.append("file", file);
        const res = await fetch(url(`api/admin/elpx/upload/${resourceId}`), {
          method: "POST",
          credentials: "include",
          body: formData,
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error((err as Record<string, string>).error || "Error al subir");
        }
      }

      statusEl.textContent = `Archivo "${file.name}" subido correctamente. Recargando...`;
      statusEl.className = "edit-upload-status edit-upload-success";
      setTimeout(() => window.location.reload(), 1000);
    } catch (err) {
      statusEl.textContent = `Error: ${(err as Error).message || "No se pudo subir el archivo"}`;
      statusEl.className = "edit-upload-status edit-upload-error";
    }
  }

  // --- eXeLearning integrated editor ---
  let exeReady = false;
  let exeSaving = false;
  let exeHasChanges = false;
  let exeElpxHash: string | null = null;
  let exeElpxFileUrl: string | null = null;
  let exeElpxFilename: string | null = null;
  let exeResourceId: string | null = null;
  let reqCounter = 0;

  const exeModal = document.getElementById("exe-editor-modal")!;
  let exeIframe = document.getElementById("exe-iframe") as HTMLIFrameElement;
  const exeStatus = document.getElementById("exe-status")!;
  const exeSaveBtn = document.getElementById("exe-save-btn") as HTMLButtonElement;
  const exeCloseBtn = document.getElementById("exe-close-btn")!;
  const exeSavingOverlay = document.getElementById("exe-saving-overlay")!;
  const isPreviewMode = !!(window as Record<string, unknown>).__PREVIEW_MODE__;

  function nextReqId(p: string) { return `${p}-${Date.now()}-${++reqCounter}`; }
  function postToExe(msg: Record<string, unknown>, transferables?: Transferable[]) {
    exeIframe.contentWindow?.postMessage(msg, "*", transferables ?? []);
  }

  function openExeEditor(resourceId: string, elpxHash: string | null, elpxFileUrl: string | null, elpxFilename: string | null) {
    exeResourceId = resourceId;
    exeElpxHash = elpxHash;
    exeElpxFileUrl = elpxFileUrl;
    exeElpxFilename = elpxFilename;
    exeReady = false; exeSaving = false; exeHasChanges = false;
    exeSaveBtn.disabled = true;
    exeStatus.textContent = "Cargando editor...";
    exeModal.style.display = "flex";
    document.body.style.overflow = "hidden";

    if (isPreviewMode) {
      exeIframe.src = url("exelearning-editor-loader.html") + `?resourceId=${resourceId}`;
    } else {
      const editorPage = url("api/v1/exelearning-editor/index.html");
      const elpxParam = elpxFileUrl ? encodeURIComponent(elpxFileUrl) : "";
      exeIframe.src = `${editorPage}?elpxUrl=${elpxParam}&resourceId=${resourceId}`;
    }
  }

  function closeExeEditor(force = false) {
    if (exeHasChanges && !force && !confirm("Hay cambios sin guardar. ¿Cerrar?")) return;
    exeModal.style.display = "none";
    // Replace iframe with a fresh clone to destroy all event listeners
    // (including the editor's beforeunload addEventListener) without
    // triggering a "Leave site?" dialog on navigation.
    const newIframe = exeIframe.cloneNode(false) as HTMLIFrameElement;
    newIframe.src = "about:blank";
    exeIframe.parentNode!.replaceChild(newIframe, exeIframe);
    exeIframe = newIframe;
    document.body.style.overflow = "";
  }

  async function handleExeSave(payload: { bytes: ArrayBuffer; filename: string; mimeType: string }) {
    exeSaving = true; exeSaveBtn.disabled = true;
    exeStatus.textContent = "Guardando...";
    exeSavingOverlay.style.display = "flex";
    try {
      const blob = new Blob([payload.bytes], { type: payload.mimeType || "application/zip" });
      if (isPreviewMode) {
        const { saveElpxInPreview } = await import("../../lib/elpx-preview-service.ts");
        const result = await saveElpxInPreview({ resourceId: exeResourceId!, blob, filename: payload.filename || "project.elpx", existingHash: exeElpxHash || undefined });
        exeElpxHash = result.hash;
        postToExe({ type: "WP_SAVE_CONFIRMED", requestId: nextReqId("confirmed") });
      } else {
        const fd = new FormData();
        fd.append("file", blob, payload.filename || "project.elpx");
        const res = await fetch(url(`api/admin/elpx/save/${exeResourceId}`), { method: "POST", credentials: "include", body: fd });
        if (!res.ok) throw new Error("Error al guardar");
        postToExe({ type: "WP_SAVE_CONFIRMED", requestId: nextReqId("confirmed") });
      }
      exeHasChanges = false;
      exeStatus.textContent = "Guardado";
      exeSavingOverlay.style.display = "none";
      setTimeout(() => { closeExeEditor(true); window.location.reload(); }, 800);
    } catch (err) {
      exeStatus.textContent = `Error: ${(err as Error).message}`;
      exeSaveBtn.disabled = false;
      exeSavingOverlay.style.display = "none";
    } finally { exeSaving = false; }
  }

  async function sendElpxToExeEditor() {
    if (!isPreviewMode) return;
    const { loadElpxBlob } = await import("../../lib/elpx-preview-service.ts");
    const blob = exeElpxHash ? await loadElpxBlob(exeElpxHash, exeElpxFileUrl) : null;
    if (blob) {
      const bytes = await blob.arrayBuffer();
      postToExe({ type: "OPEN_FILE", data: { bytes, filename: exeElpxFilename || "project.elpx" } }, [bytes]);
    }
  }

  window.addEventListener("message", (event) => {
    if (!event.data?.type || event.source !== exeIframe.contentWindow) return;
    switch (event.data.type) {
      case "EXELEARNING_READY":
        exeReady = true; exeStatus.textContent = "Editor listo";
        postToExe({ type: "CONFIGURE", requestId: nextReqId("cfg"), data: { hideUI: { fileMenu: true, saveButton: true, userMenu: true } } });
        if (isPreviewMode) sendElpxToExeEditor();
        break;
      case "DOCUMENT_LOADED": exeStatus.textContent = "Documento cargado"; exeSaveBtn.disabled = false; break;
      case "DOCUMENT_CHANGED": exeHasChanges = true; exeStatus.textContent = "Cambios sin guardar"; exeSaveBtn.disabled = false; break;
      case "WP_SAVE_FILE": if (event.data.bytes) handleExeSave(event.data); break;
      case "WP_REQUEST_SAVE_ERROR": exeStatus.textContent = `Error: ${event.data.error}`; exeSaveBtn.disabled = false; exeSaving = false; exeSavingOverlay.style.display = "none"; break;
    }
  });

  exeSaveBtn.addEventListener("click", () => {
    if (exeSaving || !exeReady) return;
    exeSaving = true; exeSaveBtn.disabled = true; exeStatus.textContent = "Exportando...";
    exeSavingOverlay.style.display = "flex";
    postToExe({ type: "WP_REQUEST_SAVE", requestId: nextReqId("export") });
  });

  exeCloseBtn.addEventListener("click", () => closeExeEditor());
  window.addEventListener("beforeunload", (e) => { if (exeHasChanges && exeModal.style.display !== "none") e.preventDefault(); });

  init();
</script>


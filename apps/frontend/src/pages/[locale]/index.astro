---
import { locales, baseLocale } from "../../paraglide/runtime.js";
import PublicLayout from "../../layouts/PublicLayout.astro";
import { HeroIsland } from "../../islands/home/HeroIsland.tsx";
import { FeaturedResourcesIsland } from "../../islands/home/FeaturedResourcesIsland.tsx";
import { setSsrLocale } from "../../lib/i18n.ts";
import * as m from "../../paraglide/messages.js";

export function getStaticPaths() {
  return locales
    .filter((l) => l !== baseLocale)
    .map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
setSsrLocale(locale);
---

<PublicLayout title={m.nav_home()} fullWidth={true} activePage="inicio">
  <HeroIsland client:load />

  <!-- Stats Section — overlaps hero with negative margin -->
  <section class="stats-section" aria-label={m.home_stats_label()}>
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-number">105k+</div>
        <div class="stat-label">{m.home_stats_resources()}</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">42k</div>
        <div class="stat-label">{m.home_stats_teachers()}</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">12k</div>
        <div class="stat-label">{m.home_stats_collections()}</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">850</div>
        <div class="stat-label">{m.home_stats_communities()}</div>
      </div>
    </div>
  </section>

  <!-- Featured Resources — Bento Grid -->
  <section class="featured-section" aria-label={m.home_featured_title()}>
    <div class="featured-section-inner">
      <div class="section-header">
        <div>
          <h2 class="section-title">{m.home_featured_title()}</h2>
          <p class="section-subtitle">{m.home_featured_subtitle()}</p>
        </div>
        <a href="explorar" class="section-link">
          {m.home_featured_see_all()}
          <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
      <FeaturedResourcesIsland client:visible />
    </div>
  </section>

  <!-- Collections — full-width tinted background -->
  <section class="collections-section" aria-label={m.home_collections_title()}>
    <div class="collections-inner">
      <div class="collections-header">
        <h2 class="section-title">{m.home_collections_title()}</h2>
        <div class="collections-arrows">
          <button class="collections-arrow-btn" aria-label={m.home_collections_prev()}>
            <span class="material-symbols-outlined" aria-hidden="true">chevron_left</span>
          </button>
          <button class="collections-arrow-btn" aria-label={m.home_collections_next()}>
            <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
          </button>
        </div>
      </div>
      <div class="collections-grid">
        <a href="explorar?collection=ia-en-el-aula" class="collection-card">
          <div class="collection-image">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuB0FIbUl9d_9m4ZjbvwtWE5h9_cjzSNFuk0ipVPTaz20KrYAjHVbP-IR7tqBTK3ukJv9OUT2xU1TJT36bx7-lytWIlcq-r3JOpC0aYKAWQnrYDsOjs3OTE-RP_VnmbIxXFf7YAFrVAgMoSd4TZlAbWufwuwyrCMany-wOgO-G8BzxeO3gkokpK2L1s7pfvfGL4MIGH4zqp1QnzGv8KZXqZb8_YHFbdZvyqC_Tf3t3HNUskExGZ3f1d5CAPBas8TDatYm3Di2AbppK8" alt="IA en el Aula" loading="lazy" />
            <div class="collection-image-overlay"></div>
          </div>
          <h4 class="collection-title">IA en el Aula</h4>
          <p class="collection-count">42 Recursos curados</p>
          <div class="collection-avatars">
            <div class="collection-avatar" style="background: #cbd5e1;"></div>
            <div class="collection-avatar" style="background: #94a3b8;"></div>
            <div class="collection-avatar" style="background: #64748b;"></div>
            <div class="collection-avatar collection-avatar-count">+12</div>
          </div>
        </a>
        <a href="explorar?collection=ods-sostenibilidad" class="collection-card">
          <div class="collection-image">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAKTQKzJ-QNCWfPJ9H1I3BoWVuhGB_0qh37eRHB9xtwBUCcdE7HmMTSbB8BmkqG73HxJWnoYjmjZI-0NI4XFXnGItdomTexyCfA2UeZ8PUlvs1gcdZV9JSP23BHrm2qqTICp7qiSplUuAiBkDaPjn1muQ8DyJBowBwR0AMwHUVWJcGi8FYLXdN72g8RYyIRF110oCPMF5av3uGJibzUjrN9g4TIU6fvOHq4AsxkmYCLb9X90j3owroCzEiRoX-wejgL9TEuRHQM_jg" alt="ODS y Sostenibilidad" loading="lazy" />

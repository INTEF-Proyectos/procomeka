            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuA5wYjz8t4-gJ6QxVmto117raZ6G5JO6Eg4tuJJbzljhMzG1ceu2dnjxogaUU-z74n8UznQtuEt9hYiNznKP90WUpAH5L_G_prY3EU-oQ1w_GAwpHceGan9Gq0O7G4nTYz2241wITNJhWinqsxAF2Jhff7oLO9W8sgOhDhqzoWgsiDMTSI4neeOYR6gQj30YxpdF4ZMjdSBVKRN5lNmpFs_ZxvaW5eUN49W3tyhUBUKJK1_mgaDddXiGyE9zompL9-M2oASvfUcU4I" alt="Gamificación Musical" loading="lazy" />
            <div class="collection-image-overlay"></div>
          </div>
          <h4 class="collection-title">Gamificación Musical</h4>
          <p class="collection-count">28 Recursos curados</p>
          <div class="collection-avatars">
            <div class="collection-avatar" style="background: #cbd5e1;"></div>
            <div class="collection-avatar collection-avatar-count">+2</div>
          </div>
        </a>
        <a href="explorar?collection=abp-secundaria" class="collection-card">
          <div class="collection-image">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCJghYk1Hpc4WjnkENQuH63VZ67vUIJy83KIuHo20UxT6XHDUSV7LbfToWXvo9-J1xKV1ryAG_620Yq1SVhSbi8ULwpWS8WlE6QRL-EnLEOXezBmoCg2BMVYiKyz0x8DrH0119US_GYEigYFP0UpwU7AZymvW1yoJb2K9ZCsmM-XiG6drGNDe1I7Gk0DdF92mbHVp4_dafxGak64jlbVlHN8j4xrPVBFO_JkZlKmnUFwUYH4tesmu_V1tOL2Kk2-jjzA8p6Zwe16_8" alt="ABP en Secundaria" loading="lazy" />
            <div class="collection-image-overlay"></div>
          </div>
          <h4 class="collection-title">ABP en Secundaria</h4>
          <p class="collection-count">156 Recursos curados</p>
          <div class="collection-avatars">
            <div class="collection-avatar" style="background: #cbd5e1;"></div>
            <div class="collection-avatar" style="background: #94a3b8;"></div>
            <div class="collection-avatar" style="background: #64748b;"></div>
            <div class="collection-avatar collection-avatar-count">+99</div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA — dark rounded container -->
  <section class="cta-section" aria-label={m.home_cta_title()}>
    <div class="cta-container">
      <div class="cta-gradient-overlay" aria-hidden="true"></div>
      <div class="cta-left">
        <h2 class="cta-title">{m.home_cta_title()}</h2>
        <p class="cta-description">{m.home_cta_description()}</p>
        <div class="cta-buttons">
          <a href="registro" class="cta-btn-primary">{m.home_cta_start()}</a>
          <a href="sobre" class="cta-btn-ghost">{m.home_cta_learn_more()}</a>
        </div>
      </div>
      <div class="cta-right">
        <div class="cta-feature-card">
          <span class="material-symbols-outlined cta-feature-icon" aria-hidden="true">group</span>
          <h4 class="cta-feature-title">{m.home_cta_communities()}</h4>
          <p class="cta-feature-desc">{m.home_cta_communities_desc()}</p>
        </div>
        <div class="cta-feature-card">
          <span class="material-symbols-outlined cta-feature-icon" aria-hidden="true">upload_file</span>
          <h4 class="cta-feature-title">{m.home_cta_publish()}</h4>
          <p class="cta-feature-desc">{m.home_cta_publish_desc()}</p>
        </div>
        <div class="cta-feature-card">
          <span class="material-symbols-outlined cta-feature-icon" aria-hidden="true">auto_awesome</span>
          <h4 class="cta-feature-title">{m.home_cta_itineraries()}</h4>
          <p class="cta-feature-desc">{m.home_cta_itineraries_desc()}</p>
        </div>
        <div class="cta-feature-card">
          <span class="material-symbols-outlined cta-feature-icon" aria-hidden="true">shield_with_heart</span>
          <h4 class="cta-feature-title">{m.home_cta_quality()}</h4>
          <p class="cta-feature-desc">{m.home_cta_quality_desc()}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest News -->
  <section class="news-section" aria-label={m.home_news_title()}>
    <div class="news-inner">
      <div class="news-header">
        <h2 class="section-title section-title-sm">{m.home_news_title()}</h2>
        <a href="explorar" class="news-feed-link">{m.home_news_see_feed()}</a>
      </div>
      <div class="news-grid">
        <a href="explorar" class="news-card">
          <div class="news-image">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCyLgNBZBAuhsyTttEdR0uA9v3XOyx-ipogOwxaIyJ63jYviZdPCrX_PsfJj4-4MtgPfRz94Ey6vv53aiV-WiCxHLKHJBmoSjEGxyZbfq3WQFAUpMZ66Chtw3azbodozn6d8OXiF62RBybfjwtddpiec1b05FZeluUmPUNNISy5DSceu_iS45kfWXsh8CTTe79i5UnTSK3HsElCHz1pz4rSBAUyZ_3o_w4ZTO8K1BXz85EOz0w6pfL2U2Yxmw5dXp1RutcgXxQLAtU" alt="Diccionario Visual de Emociones" loading="lazy" />
          </div>
          <span class="news-timestamp">Hace 2 horas</span>
          <h5 class="news-title">Diccionario Visual de Emociones para Infantil</h5>
        </a>
        <a href="explorar" class="news-card">
          <div class="news-image">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuA6PcqKC_LtrRviymqchOEGW4Qrpb8ZpNyZ8xzR3RUsE3ns_dSZAfHwiCSPLCg4IxIR1l9cISZNR_7ktosJiBDhV3eYA2HJzabGsm5Z1jfD-3Dmo8AlV1oT0fwSh0OX0iHt5BhYMYu6ESYhaVQqQbk90KxJpIO748hI5gDZBn8NnZY6ooS5pQKH0y_mq6mfFSDw052R3ZgOBvxKa3g7Ld5aE1lt7pEOQ29o7ar5Zj_lBt2nipOGsQw0ZpCxBC9Ln3SE8aBtCElawr4" alt="Taller de Criptografía" loading="lazy" />
          </div>
          <span class="news-timestamp">Hace 5 horas</span>
          <h5 class="news-title">Taller de Criptografía básica para 4º ESO</h5>
        </a>
        <a href="explorar" class="news-card">
          <div class="news-image">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAOtCHsN1v8YCXw5t6O8u2NNXlSDDZ_PIdDCiVp_B3WqbOIQsKYZDL8Xr2abYxK_GJgPkxOFYgubfa335hU8wP-PlAMDZTh1_tz7PTsm-dKuUHik4RHCdx3TvRlDMn3jaPDrrxa_xwdXvxBFBaZbdtQJpYOvW9sQkYDAbUSiFjD1VaftmhsHLmPt_uMO6z4XoweaRJW6HWQQ9Zb_tTiS7zWFhFMU_S4gc6ORBB_4lMG4N7hOf0qFnWXZiC8olS-Q8QL9mVO_z8HG9M" alt="La Ruta de la Seda" loading="lazy" />
          </div>
          <span class="news-timestamp">Ayer</span>

      </div>
    </div>
  </section>
</PublicLayout>

<style>
  /* ===== Stats Section — overlaps hero ===== */
  .stats-section {
    max-width: 80rem;
    margin: -3rem auto 5rem;
    padding: 0 var(--space-6);
    position: relative;
    z-index: 1;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  @media (min-width: 769px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat-card {
    background: var(--color-surface-container-lowest);
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    text-align: center;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: var(--weight-extrabold);
    color: var(--color-primary);
  }

  .stat-label {
    font-size: var(--text-body-sm);
    color: var(--color-outline);
    font-weight: var(--weight-medium);
  }

  /* ===== Featured Resources Section ===== */
  .featured-section {
    padding: var(--space-20) 0;
  }

  .featured-section-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-12);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: var(--weight-extrabold);
    color: var(--color-on-surface);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-2);
  }

  .section-title-sm {
    font-size: 1.875rem;
  }

  .section-subtitle {
    color: var(--color-on-surface-variant);
    max-width: 36rem;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    text-decoration: none;
    transition: gap var(--transition-fast);
    white-space: nowrap;
  }

  .section-link:hover {
    gap: 0.75rem;
    text-decoration: none;
  }

  .section-link .material-symbols-outlined {
    font-size: 20px;
  }

  /* ===== Collections Section — full-width tinted bg ===== */
  .collections-section {
    background: var(--color-surface-container-low);
    padding: var(--space-24) 0;
  }

  .collections-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .collections-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-12);
  }

  .collections-arrows {
    display: flex;
    gap: var(--space-2);
  }

  .collections-arrow-btn {
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-outline-variant);
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color var(--transition-fast);
    color: var(--color-on-surface);
  }

  .collections-arrow-btn:hover {
    background: var(--color-surface-container-lowest);
  }

  .collections-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 769px) {
    .collections-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .collection-card {
    background: var(--color-surface-container-lowest);
    padding: var(--space-6);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: box-shadow var(--transition-base);
  }

  .collection-card:hover {
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

  .collection-image {
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-bottom: var(--space-4);
    position: relative;
  }

  .collection-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .collection-image-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 63, 177, 0.2);
    transition: background-color var(--transition-fast);
  }

  .collection-card:hover .collection-image-overlay {
    background: rgba(0, 63, 177, 0);
  }

  .collection-title {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
    color: var(--color-on-surface);
  }

  .collection-count {
    font-size: var(--text-body-sm);
    color: var(--color-outline);
    margin-bottom: 0.75rem;
  }

  .collection-avatars {
    display: flex;
  }

  .collection-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-full);
    border: 2px solid white;
    margin-left: -0.5rem;
  }

  .collection-avatar:first-child {
    margin-left: 0;
  }

  .collection-avatar-count {
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: var(--weight-bold);
  }

  /* ===== CTA Section ===== */
  .cta-section {
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--space-24) var(--space-6);
  }

  .cta-container {
    background: var(--color-on-surface);
    color: var(--color-surface-container-lowest);
    border-radius: 3rem;
    padding: 3rem;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-12);
  }

  @media (min-width: 769px) {
    .cta-container {
      flex-direction: row;
      padding: 5rem;
    }
  }

  .cta-gradient-overlay {
    position: absolute;
    inset: 0;
    opacity: 0.1;
    background: radial-gradient(circle at center, white, transparent, transparent);
  }

  .cta-left {
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-6);
  }

  .cta-description {
    color: var(--color-surface-variant);
    font-size: 1.125rem;
    max-width: 36rem;
    margin-bottom: var(--space-10);
  }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .cta-btn-primary {
    background: var(--color-primary);
    color: var(--color-on-primary);
    padding: var(--space-4) var(--space-8);
    border-radius: var(--radius-full);
    font-weight: var(--weight-bold);
    font-size: 1.125rem;
    text-decoration: none;
    box-shadow: var(--shadow-xl), var(--shadow-primary);
    transition: transform var(--transition-fast);
    display: inline-block;
  }

  .cta-btn-primary:hover {
    transform: scale(1.05);
    text-decoration: none;
  }

  .cta-btn-ghost {
    background: rgba(255, 255, 255, 0.1);
    color: white;
    padding: var(--space-4) var(--space-8);
    border-radius: var(--radius-full);
    font-weight: var(--weight-bold);
    font-size: 1.125rem;
    text-decoration: none;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: background-color var(--transition-fast);
    display: inline-block;
  }

  .cta-btn-ghost:hover {
    background: rgba(255, 255, 255, 0.2);
    text-decoration: none;
  }

  .cta-right {
    flex: 1;
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    width: 100%;
  }

  .cta-feature-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding: var(--space-6);
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cta-feature-icon {
    font-size: 1.875rem;
    color: var(--color-secondary-container);
  }

  .cta-feature-title {

            <div class="collection-avatar" style="background: #cbd5e1;"></div>
            <div class="collection-avatar" style="background: #94a3b8;"></div>
            <div class="collection-avatar collection-avatar-count">+5</div>
          </div>
        </a>
        <a href="explorar?collection=gamificacion-musical" class="collection-card">

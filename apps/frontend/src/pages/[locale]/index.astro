        <a href="explorar" class="news-card">
          <div class="news-image">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAMUvRKSy1EbjWHrhcVmHdSvctACIjl5_aHGDDrlTnrY-0P2QR0wHC1NN4ZRyKCj1WfWv2q1NGRSePpUkD8x2cbMTX4ZyArLSiCSF747rasEzSWDohr3gsFOsviaIH2BnpuhC0k86nSBJAVBuM9rcHPWYdKPSR49xMCdOkgSTmojJABdlotBi1gi1zNxSv6l5Kr2Zv-HvMvPfUd6rwmdstVpVTg1QHt0BiMK2RKfs82vfdw70JL5wocQzngIS19Jnif0sn7uk-8Ya8" alt="Manual de Accesibilidad" loading="lazy" />
          </div>
          <span class="news-timestamp">Ayer</span>
          <h5 class="news-title">Manual de Accesibilidad para Contenidos Digitales</h5>

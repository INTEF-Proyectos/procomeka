---
import AdminLayout from "../layouts/AdminLayout.astro";
---

<AdminLayout title="Panel">
	<div class="dashboard-container">
		<div id="loading">Cargando sesión...</div>

		<div id="not-authenticated" style="display:none;">
			<p>No has iniciado sesión.</p>
			<a id="login-link" href="#">Iniciar sesión</a>
		</div>

		<div id="authenticated" style="display:none;">
			<h1>Bienvenido, <span id="user-name"></span></h1>
			<p class="welcome-text">Has accedido al panel de gestión de Procomeka.</p>

			<div class="user-info">
				<p><strong>Email:</strong> <span id="user-email"></span></p>
				<p><strong>Rol:</strong> <span id="user-role" class="badge"></span></p>
			</div>

			<div class="shortcuts">
				<h2>Acciones rápidas</h2>
				<div class="grid">
					<div id="author-actions" class="card" style="display:none;">
						<h3>Recursos</h3>
						<p>Sube y gestiona tus recursos educativos.</p>
						<a id="create-link" href="#" class="btn">Nuevo recurso</a>
						<a id="manage-resources-link" href="#" class="btn-outline">Mis recursos</a>
					</div>

					<div id="curator-actions" class="card" style="display:none;">
						<h3>Curación</h3>
						<p>Revisa y aprueba el contenido del catálogo.</p>
						<a id="curate-link" href="#" class="btn">Revisar pendientes</a>
					</div>

					<div id="admin-actions" class="card" style="display:none;">
						<h3>Administración</h3>
						<p>Gestiona usuarios, roles y taxonomías.</p>
						<a id="manage-users-link" href="#" class="btn">Gestionar usuarios</a>
						<a id="manage-categories-link" href="#" class="btn-outline">Taxonomías</a>
					</div>
				</div>
			</div>

			<button id="logout-btn">Cerrar sesión</button>
		</div>
	</div>
</AdminLayout>

<script>
	import { getApiClient } from "../lib/get-api-client.ts";
	import { url } from "../lib/paths.ts";

	// Configurar hrefs con base path
	const loginLink = document.getElementById("login-link") as HTMLAnchorElement;
	const createLink = document.getElementById("create-link") as HTMLAnchorElement;
	const manageResourcesLink = document.getElementById("manage-resources-link") as HTMLAnchorElement;
	const curateLink = document.getElementById("curate-link") as HTMLAnchorElement;
	const manageUsersLink = document.getElementById("manage-users-link") as HTMLAnchorElement;
	const manageCategoriesLink = document.getElementById("manage-categories-link") as HTMLAnchorElement;

	if (loginLink) loginLink.href = url("login");
	if (createLink) createLink.href = url("admin/recursos/nuevo");
	if (manageResourcesLink) manageResourcesLink.href = url("admin/recursos");
	if (curateLink) curateLink.href = url("admin/recursos?status=review");
	if (manageUsersLink) manageUsersLink.href = url("admin/usuarios");
	if (manageCategoriesLink) manageCategoriesLink.href = url("admin/categorias");

	async function loadSession() {
		const loading = document.getElementById("loading") as HTMLDivElement;
		const notAuth = document.getElementById("not-authenticated") as HTMLDivElement;
		const auth = document.getElementById("authenticated") as HTMLDivElement;

		try {
			const api = await getApiClient();
			const session = await api.getSession();

			if (!session?.user) {
				loading.style.display = "none";
				notAuth.style.display = "block";
				return;
			}

			const user = session.user;
			(document.getElementById("user-name") as HTMLSpanElement).textContent = user.name;
			(document.getElementById("user-email") as HTMLSpanElement).textContent = user.email;

			const roleBadge = document.getElementById("user-role") as HTMLSpanElement;
			roleBadge.textContent = user.role ?? "reader";
			roleBadge.className = `badge badge-${user.role ?? "reader"}`;

			const role = user.role ?? "reader";
			const roleHierarchy = ["reader", "author", "curator", "admin"];
			const level = roleHierarchy.indexOf(role);

			if (level >= 1) {
				(document.getElementById("author-actions") as HTMLDivElement).style.display = "block";
			}
			if (level >= 2) {
				(document.getElementById("curator-actions") as HTMLDivElement).style.display = "block";
			}
			if (level >= 3) {
				(document.getElementById("admin-actions") as HTMLDivElement).style.display = "block";
			}

			loading.style.display = "none";
			auth.style.display = "block";
		} catch {
			loading.style.display = "none";
			notAuth.style.display = "block";
		}
	}

	document.getElementById("logout-btn")?.addEventListener("click", async () => {
		const api = await getApiClient();
		await api.signOut();
		window.location.href = url("login");
	});

	loadSession();
</script>

<style>
	.dashboard-container {
		max-width: 900px;
		margin: 0 auto;
	}

	.welcome-text {
		color: #6b7280;
		margin-bottom: 2rem;
	}

	.user-info {
		background: #f3f4f6;
		padding: 1rem;
		border-radius: 8px;
		margin-bottom: 2rem;
		display: flex;
		gap: 2rem;
		align-items: center;
	}

	.user-info p {
		margin: 0;
	}

	.shortcuts {
		margin-bottom: 3rem;
	}

	.shortcuts h2 {
		font-size: 1.25rem;
		margin-bottom: 1.5rem;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.5rem;
	}

	.card {
		border: 1px solid #e5e7eb;
		padding: 1.5rem;
		border-radius: 8px;
		background: white;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.card:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
	}

	.card h3 {
		font-size: 1.1rem;
		margin-top: 0;
		margin-bottom: 0.75rem;
	}

	.card p {
		font-size: 0.9rem;
		color: #4b5563;
		margin-bottom: 1.25rem;
	}

	.btn {
		display: inline-block;
		padding: 0.5rem 1rem;
		background: #1a56db;
		color: white;
		text-decoration: none;
		border-radius: 6px;
		font-size: 0.875rem;
		font-weight: 500;
		margin-right: 0.5rem;
	}

	.btn:hover { background: #1e40af; }

	.btn-outline {
		display: inline-block;
		padding: 0.5rem 1rem;
		background: white;
		color: #374151;
		border: 1px solid #d1d5db;
		text-decoration: none;
		border-radius: 6px;
		font-size: 0.875rem;
		font-weight: 500;
	}

	.btn-outline:hover { background: #f9fafb; }

	.badge {
		display: inline-block;
		padding: 0.25rem 0.75rem;
		border-radius: 9999px;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
	}

	.badge-admin { background: #fecaca; color: #991b1b; }
	.badge-curator { background: #dbeafe; color: #1e40af; }
	.badge-author { background: #d1fae5; color: #065f46; }
	.badge-reader { background: #e5e7eb; color: #374151; }

	button {
		padding: 0.625rem 1.25rem;
		background: #ef4444;
		color: white;
		border: none;
		border-radius: 6px;
		cursor: pointer;
		font-weight: 500;
		font-size: 0.875rem;
	}

	button:hover { background: #dc2626; }

	#loading { color: #9ca3af; text-align: center; padding: 2rem; }
</style>

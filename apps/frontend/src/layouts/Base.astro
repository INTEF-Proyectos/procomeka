---
import { BaseNavIsland } from "../islands/layout/BaseNavIsland.tsx";
import PreviewBanner from "../components/PreviewBanner.astro";
import "../styles/design-tokens.css";
import "../styles/reset.css";
import "../styles/utilities.css";

interface Props {
	title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
const isPreview = import.meta.env.PUBLIC_PREVIEW_MODE === "true";
const hasHeaderCenter = Astro.slots.has("header-center");
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title} — Procomeka</title>
		<link rel="preload" href="/fonts/inter-v18-latin-regular.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/plus-jakarta-sans-v8-latin-600.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" />
		<script define:vars={{ base, isPreview }}>
			window.__BASE_URL__ = base;
			window.__PREVIEW_MODE__ = isPreview;
		</script>
	</head>
	<body class={isPreview ? "has-preview-banner" : ""}>
		<a href="#main-content" class="sr-only">Saltar al contenido</a>
		<header class="site-header">
			<nav class={`site-nav${hasHeaderCenter ? " nav-with-center" : ""}`} aria-label="Navegación principal">
				<a href={base} class="brand">Procomeka</a>
				{hasHeaderCenter && (
					<div class="nav-center">
						<slot name="header-center" />
					</div>
				)}
				<BaseNavIsland client:load />
			</nav>
		</header>
		<main id="main-content">
			<slot />
		</main>
		<footer class="site-footer" role="contentinfo">
			<p>Plataforma de recursos educativos abiertos</p>
		</footer>
		<PreviewBanner />
	</body>
</html>

<style is:global>
	/* Preview banner spacing */
	body.has-preview-banner {
		padding-bottom: 2.5rem;
	}

	/* Site header */
	.site-header {
		background: var(--color-surface-container-lowest);
		padding: var(--space-3) var(--space-6);
	}

	.site-nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.site-nav.nav-with-center {
		gap: var(--space-4);
	}

	.brand {
		font-family: var(--font-display);
		font-weight: var(--weight-bold);
		font-size: var(--text-title-lg);
		text-decoration: none;
		color: var(--color-text);
		white-space: nowrap;
	}

	.brand:hover {
		text-decoration: none;
		color: var(--color-primary);
	}

	.nav-center {
		flex: 1;
		max-width: 480px;
	}

	.nav-links {
		display: flex;
		gap: var(--space-4);
		white-space: nowrap;
	}

	.nav-links a {
		color: var(--color-text-secondary);
		text-decoration: none;
		font-size: var(--text-body-md);
		font-weight: var(--weight-medium);
		transition: color var(--transition-fast);
	}

	.nav-links a:hover {
		color: var(--color-primary);
		text-decoration: none;
	}

	/* Main content */
	#main-content {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: var(--space-6);
	}

	/* Footer */
	.site-footer {
		padding: var(--space-4) var(--space-6);
		text-align: center;
		color: var(--color-text-secondary);
		font-size: var(--text-body-sm);
		margin-top: var(--space-12);
		background: var(--color-surface-container-low);
	}

	/* Material Symbols */
	.material-symbols-outlined {
		font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
		vertical-align: middle;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.site-nav.nav-with-center {
			flex-wrap: wrap;
		}

		.nav-center {
			order: 3;
			max-width: 100%;
			flex-basis: 100%;
		}

		#main-content {
			padding: var(--space-4);
		}
	}
</style>
